# BHTX 服务端环境变量模板
# 使用方式：复制本文件为 .env，填入真实值。.env 已被 .gitignore 忽略，不会上传。
# 切勿把真实值写进本文件或任何会被提交的文件中。

# 微信小程序 AppSecret（从微信公众平台「开发管理 → 开发设置」获取）
WX_APP_SECRET=your_wechat_app_secret_here

# JWT 签名密钥：用 `openssl rand -hex 32` 生成一个随机串
JWT_SECRET=generate_with_openssl_rand_hex_32

# 163 邮箱（用于发送验证码）
SMTP_USER=bhtxadmin@163.com
SMTP_PASS=your_163_mail_password_here

# 复制统计接口的管理密钥（自定义任意字符串）
ADMIN_KEY=change_me
