page {
  height: 100vh;
  background: #f5f7fb;
}

.about-page {
  min-height: 100vh;
  padding: 48rpx 16rpx;
  box-sizing: border-box;
}

.about-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.about-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 28rpx;
}

.about-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 10rpx;
}

.about-version {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 40rpx;
}

.about-desc {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.9;
}
