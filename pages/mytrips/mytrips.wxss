page {
  height: 100vh;
  background: #f5f7fb;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  box-sizing: border-box;
}

.trip-list {
  flex: 1;
  padding: 18rpx 12rpx 170rpx;
  box-sizing: border-box;
}

.empty-state,
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 140rpx;
  padding: 24rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.trip-card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(18, 38, 63, 0.08);
}

.trip-main {
  display: flex;
  gap: 28rpx;
  align-items: center;
}

.trip-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 20rpx;
  min-width: 0;
}

.trip-datetime {
  font-size: 40rpx;
  font-weight: 400;
  color: #111827;
  line-height: 1.3;
}

.trip-route {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  font-size: 30rpx;
  font-weight: 400;
  color: #374151;
}

.route-text {
  max-width: 340rpx;
}

.route-arrow {
  margin: 0 10rpx;
  color: #9ca3af;
}

.trip-status {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #16a34a;
  background: #e8f8ee;
}

.trip-status.expired-badge {
  color: #9ca3af;
  background: #f3f4f6;
}

.immediate-card {
  border-left: 8rpx solid #ff6b35;
}

.immediate-card .trip-datetime {
  color: #ff6b35;
}

.immediate-status {
  color: #ff6b35;
  background: #fff4f0;
}

.card-actions {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.deactivate-btn {
  min-width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 25rpx;
  color: #ffffff;
  background: #ef4444;
}

.deactivate-btn::after {
  border: none;
}

.safety-tip {
  padding: 20rpx 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
  background: #f9fafb;
}

.trip-remark {
  font-size: 24rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
