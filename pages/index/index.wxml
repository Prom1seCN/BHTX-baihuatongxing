<view class="hall-page">
  <scroll-view
    class="trip-scroll"
    scroll-y
    enhanced
    show-scrollbar="false"
    lower-threshold="200"
    bindscrolltolower="handleScrollToLower"
  >
    <view class="filter-panel">
      <view class="filter-group">
        <view class="filter-title">筛选日期</view>
        <scroll-view class="tag-scroll" scroll-x enhanced show-scrollbar="false">
          <view class="date-filter" style="margin-bottom: 0;">
            <view
              wx:for="{{filters.dates}}"
              wx:key="*this"
              class="date-item {{selectedDate === item ? 'active' : ''}}"
              data-value="{{item}}"
              bindtap="handleDateChange"
            >
              {{item}}
            </view>
            <picker
              mode="date"
              value="{{selectedCustomDate || pickerStart}}"
              start="{{pickerStart}}"
              end="{{pickerEnd}}"
              bindchange="handlePickerDateChange"
            >
              <view class="date-item {{selectedDate === 'CUSTOM' ? 'active' : ''}}">
                {{pickerDisplayText}}
              </view>
            </picker>
          </view>
        </scroll-view>
      </view>

      <view class="filter-group">
        <view class="filter-title">筛选出发地</view>
        <scroll-view class="tag-scroll" scroll-x enhanced show-scrollbar="false">
          <view class="tag-row">
            <view
              wx:for="{{filters.locations}}"
              wx:key="*this"
              class="tag-item {{departureActiveMap[item] ? 'active' : ''}}"
              data-value="{{item}}"
              bindtap="handleDepartureChange"
            >
              {{item}}
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="filter-group">
        <view class="filter-title">筛选目的地</view>
        <scroll-view class="tag-scroll" scroll-x enhanced show-scrollbar="false">
          <view class="tag-row">
            <view
              wx:for="{{filters.locations}}"
              wx:key="*this"
              class="tag-item {{destinationActiveMap[item] ? 'active' : ''}}"
              data-value="{{item}}"
              bindtap="handleDestinationChange"
            >
              {{item}}
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <block wx:if="{{allTrips.length}}">
      <view
        wx:for="{{allTrips}}"
        wx:key="id"
        class="trip-card {{item.tripType === 'immediate' ? 'immediate-card' : ''}}"
        data-id="{{item.id}}"
        bindtap="handleTripCardTap"
      >
        <view class="trip-status {{item.tripType === 'immediate' ? 'immediate-status' : ''}}">
          {{item.tripType === 'immediate' ? '即刻出发' : '预约同行'}}
        </view>
        <view class="trip-main">
          <view class="trip-left">
            <view class="trip-datetime">
              {{item.tripType === 'immediate' ? item.minutesLeft : item.displayDate + ' ' + item.departure_time + '出发'}}
            </view>
            <view class="trip-route">
              <text class="route-text">{{item.departure}}</text>
              <text class="route-arrow">——</text>
              <text class="route-text">{{item.destination}}</text>
            </view>
            <view wx:if="{{isVerified && item.remark}}" class="trip-remark">{{item.remark}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{isLoadingMore}}" class="loading-more">加载中...</view>
      <view wx:elif="{{!hasMore && _filteredTrips.length > PAGE_SIZE}}" class="loading-more">没有更多行程了</view>
    </block>
    <view wx:else class="empty-state">当前筛选条件下暂无行程</view>

    <view class="bottom-hint">没有同行行程? 点击+号发布行程！</view>
  </scroll-view>

</view>
