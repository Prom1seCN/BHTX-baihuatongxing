page {
  height: 100vh;
  background: #f5f7fb;
}

.legal-page {
  height: 100vh;
}

.legal-scroll {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.legal-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(17, 24, 39, 0.06);
}

.legal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.section-title {
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.6;
}

.paragraph {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  text-indent: 2em;
}

.sub-paragraph {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  padding-left: 1em;
}
