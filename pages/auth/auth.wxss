page {
  height: 100vh;
  background: #f5f7fb;
}

.auth-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.auth-scroll {
  flex: 1;
  padding: 24rpx 24rpx 170rpx;
  box-sizing: border-box;
}

.form-card {
  border-radius: 20rpx;
  overflow: hidden;
  background: #ffffff;
}

.form-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.email-row,
.code-row {
  display: flex;
  align-items: center;
}

.code-row {
  gap: 18rpx;
}

.email-input,
.code-input {
  flex: 1;
  height: 52rpx;
  font-size: 30rpx;
  color: #111827;
}

.email-suffix {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.code-btn {
  width: 220rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #2678ff;
  background: #e8f0ff;
  line-height: 1;
}

.code-btn.disabled {
  color: #9ca3af;
  background: #f3f4f6;
}

.code-btn::after {
  border: none;
}

.submit-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 20rpx rgba(17, 24, 39, 0.08);
}

.submit-btn {
  width: 100%;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 14rpx;
  font-size: 32rpx;
  color: #ffffff;
  line-height: 1;
  background: #2678ff;
}

.submit-btn::after {
  border: none;
}

.verified-wrap {
  flex: 1;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.verified-card {
  width: 100%;
  padding: 40rpx 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(17, 24, 39, 0.06);
}

.verified-title {
  font-size: 26rpx;
  color: #6b7280;
}

.verified-email {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  word-break: break-all;
}

.unbind-btn {
  margin-top: 34rpx;
  width: 100%;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  line-height: 1;
  border-radius: 14rpx;
  font-size: 30rpx;
  color: #ffffff;
  background: #ef4444;
}

.unbind-btn::after {
  border: none;
}
